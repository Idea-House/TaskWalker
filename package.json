{
  "name": "task-walker",
  "version": "1.1.0",
  "private": true,
  "description": "PowerToys Window Walker inspired task switcher UI prototype",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "predev": "npm run native",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "native": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/build-native-helper.ps1",
    "build": "npm run icons && npm run native && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "dist": "npm run build && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/build-portable.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "cross-env TASK_WALKER_SMOKE=1 electron electron/main.mjs"
  },
  "dependencies": {
    "@fluentui/react-icons": "latest",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "simple-icons": "latest"
  },
  "devDependencies": {
    "@fluentui/svg-icons": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "5.0.4",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "jsdom": "latest",
    "png-to-ico": "latest",
    "sharp": "latest",
    "typescript": "latest",
    "vite": "^6.4.3",
    "vitest": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "jp.taskwalker.prototype",
    "productName": "Task Walker",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "resources/task-walker.*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/native",
        "to": "native",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "resources/task-walker.ico",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Task-Walker-${version}-portable.${ext}"
    }
  }
}
